# GastricCare Environment Variables
# Copy these values into your Render Dashboard (Environment tab)

# --- Flask Backend ---
FLASK_SECRET_KEY=YOUR_SECRET_KEY
BREVO_API_KEY=YOUR_BREVO_KEY
SENDER_EMAIL=YOUR_SENDER_EMAIL
RAZORPAY_KEY_ID=YOUR_RAZORPAY_ID
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_SECRET

# --- Firebase Frontend (Vite) ---
VITE_FIREBASE_API_KEY=YOUR_FB_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_FB_DOMAIN
VITE_FIREBASE_PROJECT_ID=YOUR_FB_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_FB_STORAGE
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_FB_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_FB_APP_ID
